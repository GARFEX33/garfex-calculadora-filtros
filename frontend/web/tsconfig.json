{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		// ── Módulos ──────────────────────────────────────────────────────────
		"moduleResolution": "bundler",
		"rewriteRelativeImportExtensions": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,

		// ── Interoperabilidad ─────────────────────────────────────────────────
		"allowJs": true,
		"checkJs": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,

		// ── Output ────────────────────────────────────────────────────────────
		"sourceMap": true,

		// ── Strict mode COMPLETO ──────────────────────────────────────────────
		// strict: true activa: strictNullChecks, noImplicitAny, strictFunctionTypes,
		//   strictBindCallApply, strictPropertyInitialization, noImplicitThis,
		//   alwaysStrict, useUnknownInCatchVariables
		"strict": true,

		// Opciones adicionales más allá de strict
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noPropertyAccessFromIndexSignature": true,
		"exactOptionalPropertyTypes": true
	}
	// Path aliases manejados por SvelteKit:
	//   $lib → src/lib  (ver svelte.config.js)
	// Para aliases custom: agregar en svelte.config.js > kit.alias
}
