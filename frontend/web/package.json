{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint src --max-warnings=0",
		"lint:fix": "eslint src --fix",
		"format": "prettier --write src",
		"format:check": "prettier --check src",
		"qa": "npm run format:check && npm run lint && npm run check",
		"test": "vitest",
		"test:run": "vitest run",
		"test:ui": "vitest --ui",
		"prepare": "cd ../.. && node -e \"try{require('fs').statSync('.husky')}catch(e){require('fs').mkdirSync('.husky',{recursive:true})}\" && git config core.hooksPath .husky || true"
	},
	"lint-staged": {
		"*.{ts,js}": [
			"prettier --write",
			"eslint --max-warnings=0 --no-warn-ignored"
		],
		"*.svelte": [
			"prettier --write",
			"eslint --max-warnings=0 --no-warn-ignored"
		],
		"*.{css,json,md}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"@vitest/ui": "^4.0.18",
		"eslint": "^10.0.1",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1"
	}
}
