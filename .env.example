# Base de datos — Supabase local (stack GARFEXIA)
DB_HOST=host.docker.internal
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=your_supabase_postgres_password
DB_NAME=postgres

# Gotenberg — ya corre en GARFEXIA en puerto 3015
GOTENBERG_URL=http://host.docker.internal:3015/forms/chromium/convert/html

# URL pública del API — IP o dominio del servidor (la ve el navegador)
# Ejemplo: http://192.168.1.X:8080
PUBLIC_API_URL=http://localhost:8080
